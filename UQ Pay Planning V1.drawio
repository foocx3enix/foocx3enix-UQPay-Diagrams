        <mxCell id="7_QbFYXz4KgsArV6x98U-118" parent="7_QbFYXz4KgsArV6x98U-116" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" value="&lt;span style=&quot;font-size: 12px; font-weight: 700;&quot;&gt;uqpay_card_status&lt;/span&gt;" vertex="1">
          <mxGeometry height="105" width="305" x="348" as="geometry">
            <mxRectangle height="105" width="305" as="alternateBounds" />
